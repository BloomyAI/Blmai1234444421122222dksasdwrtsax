# Bloomy AI - LLM Provider API Keys
# OpenRouter (Recommended - has free models)
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Groq (Fast, free tier) - https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (Free with Google account) - https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Cerebras (Free inference) - https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# NVIDIA NIM (Free credits) - https://build.nvidia.com
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# Mistral (Free tier) - https://console.mistral.ai
MISTRAL_API_KEY=your_mistral_api_key_here

# DeepSeek (Free tier) - https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Pollinations (Free video - wan-fast) - https://enter.pollinations.ai
POLLINATIONS_API_KEY=your_pollinations_api_key_here

# Pexels (Optional stock video fallback) - https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# GitHub Releases (required for private repo desktop downloads on the website)
# Create a fine-grained PAT with read access to repo Contents + Metadata, or classic PAT with repo scope
GITHUB_RELEASES_TOKEN=ghp_your_github_token_here
# Optional override if repo is under a different org/user
# GITHUB_REPO=BloomyAI/BloomyAI
